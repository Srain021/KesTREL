{
  "mcpServers": {
    "kestrel-mcp": {
      "command": "python",
      "args": ["-m", "kestrel_mcp", "--edition", "internal", "serve"],
      "env": {
        "KESTREL_EDITION": "internal",
        "KESTREL_MCP_EDITION": "internal",
        "KESTREL_MCP_LLM__TOOL_DESCRIPTION_MODE": "compact",
        "KESTREL_MCP_LLM__TOOL_EXPOSURE": "harness_first",
        "KESTREL_MCP_LLM__MODEL_TIER": "local",
        "KESTREL_MCP_SECURITY__AUTHORIZED_SCOPE": "*.lab.internal,192.168.56.0/24,127.0.0.1",
        "SHODAN_API_KEY": "REPLACE_WITH_YOUR_KEY",
        "KESTREL_MCP_TOOLS__NUCLEI__BINARY": "C:/Users/YOU/hacking-tools/nuclei.exe",
        "KESTREL_MCP_TOOLS__SUBFINDER__BINARY": "C:/Users/YOU/hacking-tools/subfinder.exe",
        "KESTREL_MCP_TOOLS__AMASS__BINARY": "C:/Users/YOU/hacking-tools/amass.exe",
        "KESTREL_MCP_TOOLS__HTTPX__BINARY": "C:/Users/YOU/hacking-tools/httpx.exe",
        "KESTREL_MCP_TOOLS__KATANA__BINARY": "C:/Users/YOU/hacking-tools/katana.exe",
        "KESTREL_MCP_TOOLS__NMAP__BINARY": "C:/Program Files (x86)/Nmap/nmap.exe",
        "KESTREL_MCP_TOOLS__FFUF__BINARY": "C:/Users/YOU/hacking-tools/ffuf.exe",
        "KESTREL_MCP_TOOLS__SQLMAP__BINARY": "C:/Users/YOU/hacking-tools/sqlmap.exe",
        "KESTREL_MCP_TOOLS__NETEXEC__BINARY": "C:/Users/YOU/hacking-tools/nxc.exe",
        "KESTREL_MCP_TOOLS__HASHCAT__BINARY": "C:/Users/YOU/hacking-tools/hashcat.exe",
        "KESTREL_MCP_TOOLS__SLIVER__SERVER_BINARY": "C:/Users/YOU/hacking-tools/sliver-server.exe",
        "KESTREL_MCP_TOOLS__SLIVER__CLIENT_BINARY": "C:/Users/YOU/hacking-tools/sliver-client.exe",
        "KESTREL_MCP_TOOLS__LIGOLO__PROXY_BINARY": "C:/Users/YOU/hacking-tools/ligolo-ng-proxy/proxy.exe",
        "KESTREL_MCP_TOOLS__CAIDO__BINARY": "C:/Users/YOU/hacking-tools/caido-cli.exe",
        "KESTREL_MCP_TOOLS__EVILGINX__BINARY": "C:/Users/YOU/hacking-tools/evilginx.exe",
        "KESTREL_MCP_TOOLS__HAVOC__BINARY": "C:/Users/YOU/hacking-tools/Havoc/havoc.exe",
        "PYTHONUNBUFFERED": "1"
      }
    }
  }
}
