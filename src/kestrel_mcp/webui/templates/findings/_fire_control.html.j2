<aside class="rounded-2xl border border-red-200 bg-red-50 p-4 shadow-sm">
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="text-xs font-semibold uppercase tracking-wide text-red-700">Fire-control packet</p>
      <h2 class="mt-1 text-lg font-semibold text-slate-950">{{ packet.proposed_action }}</h2>
      <p class="mt-1 text-sm text-slate-600">
        Target: <span class="font-mono">{{ packet.target }}</span>
        &middot; Risk: <span class="font-semibold">{{ packet.risk_level }}</span>
        &middot; Readiness: {{ packet.readiness_rating.replace("_", " ") }} {{ packet.readiness_score }}/100
      </p>
    </div>
    <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-red-700 border border-red-200">
      Explicit human approval required
    </span>
  </div>

  <div class="mt-4 grid gap-4 md:grid-cols-2">
    <section class="rounded-xl bg-white/80 border border-red-100 p-3">
      <h3 class="text-sm font-semibold text-slate-900">Approval state</h3>
      <dl class="mt-2 text-sm text-slate-700 space-y-1">
        <div class="flex justify-between gap-3">
          <dt>Approved</dt>
          <dd class="font-mono">{{ packet.approved }}</dd>
        </div>
        <div class="flex justify-between gap-3">
          <dt>Next state</dt>
          <dd class="font-mono">{{ packet.next_state }}</dd>
        </div>
      </dl>
      <p class="mt-3 text-xs text-red-700">
        This panel does not execute tools, create jobs, or approve action by itself.
      </p>
    </section>

    <section class="rounded-xl bg-white/80 border border-red-100 p-3">
      <h3 class="text-sm font-semibold text-slate-900">Rationale</h3>
      <p class="mt-2 text-sm text-slate-700">{{ packet.rationale }}</p>
      <p class="mt-2 text-xs text-slate-500">
        Evidence ref: <span class="font-mono">{{ packet.evidence_refs[0] }}</span>
      </p>
    </section>
  </div>

  {% if packet.evidence_gaps %}
  <section class="mt-4 rounded-xl bg-white/80 border border-red-100 p-3">
    <h3 class="text-sm font-semibold text-slate-900">Evidence gaps before approval</h3>
    <ul class="mt-2 list-disc pl-5 text-sm text-slate-700">
      {% for gap in packet.evidence_gaps %}
      <li>{{ gap }}</li>
      {% endfor %}
    </ul>
  </section>
  {% endif %}

  <section class="mt-4 rounded-xl bg-white/80 border border-red-100 p-3">
    <h3 class="text-sm font-semibold text-slate-900">Commander checklist</h3>
    <ul class="mt-2 list-disc pl-5 text-sm text-slate-700">
      {% for item in packet.checklist %}
      <li>{{ item }}</li>
      {% endfor %}
    </ul>
  </section>

  <section class="mt-4 rounded-xl bg-white/80 border border-red-100 p-3">
    <h3 class="text-sm font-semibold text-slate-900">Rollback / abort guidance</h3>
    <p class="mt-2 text-sm text-slate-700">{{ packet.rollback_plan }}</p>
  </section>
</aside>
