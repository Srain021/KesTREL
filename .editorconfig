root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 100

[*.{py,pyi}]
indent_size = 4

[*.{yaml,yml,json,toml}]
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false
max_line_length = off

[*.{ps1,psm1,psd1,bat,cmd}]
end_of_line = crlf
indent_size = 4

[Makefile]
indent_style = tab

[*.html.j2]
indent_size = 2
